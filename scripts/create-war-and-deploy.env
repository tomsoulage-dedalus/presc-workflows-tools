# shellcheck shell=bash

# Single shared config file for create-war-and-deploy.
# CLI options override equivalent values from this file.
# Passing explicit mvn args appends them to DEFAULT_MAVEN_ARGS.
# Use --replace-maven-args when you want to replace them entirely.

# Base directory containing the sibling repos used by the script.
REPOS_DIR="${REPOS_DIR:-/home/orbisu/repos}"

# Where the packaging build is executed and where the WAR is produced.
PACKAGING_REPO="${REPOS_DIR}/orme-medication-packaging"
WAR_RELATIVE_PATH="deployment/orbis-medication-war/target/orbis-medication.war"
MAVEN_LOCAL_REPOSITORY="${HOME}/.m2/repository"
BUILD_COMMAND="mvn clean install"

# Default version line used when --version-line is omitted.
DEFAULT_VERSION_LINE="4.0"

# Supported version line -> version prefix mapping.
declare -A VERSION_PREFIXES=(
  ["3.22"]="3.3220000.9999"
  ["4.0"]="3.4000000.9999"
  ["4.01"]="3.4000100.9999"
)

# Deployment catalog. Commands are run from DEPLOY_WORKDIR.
# Arguments support the placeholders {war}, {ticket}, and {version}.
DEPLOY_WORKDIR="${REPOS_DIR}/orme-scripts"
DEFAULT_DEPLOY_TARGET="quick"

declare -A DEPLOY_COMMANDS=(
  ["quick"]="bash ./wsl/quick.sh"
  ["system"]="bash ./wsl/deploy.sh"
)

declare -A DEPLOY_ARGUMENTS=(
  ["quick"]="deploy {war}"
  ["system"]="{war}"
)

# Default Maven args for the noob-friendly flow.
# Advanced users can still pass custom Maven args on the command line; by default they are appended.
DEFAULT_MAVEN_ARGS="-U -Ppresc-dev -DskipTests -pl deployment/orbis-medication-war -am"
